# Environment Variables Template
# Sao chép file này thành .env và điền giá trị thực tế

# ===== DATABASE CONFIGURATION =====
# MySQL connection
DB_USERNAME=root
DB_PASSWORD=your_secure_password

# ===== JWT CONFIGURATION =====
# IMPORTANT: Tối thiểu 32 ký tự, nên sử dụng key mạnh
# Có thể generate bằng: openssl rand -base64 32
JWT_SECRET=your_very_long_and_secure_secret_key_min_32_chars

# JWT Token Expiry (milliseconds)
# 900000 = 15 minutes (access token)
# 604800000 = 7 days (refresh token)
JWT_ACCESS_TOKEN_EXPIRY=900000
JWT_REFRESH_TOKEN_EXPIRY=604800000

# ===== REDIS CONFIGURATION =====
# Redis cho caching (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== OTP CONFIGURATION =====
# OTP expiry time (seconds)
OTP_EXPIRY_SECONDS=300

# ===== EMAIL CONFIGURATION =====
# Gmail hoặc email provider khác
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@library.local

# ===== APPLICATION CONFIGURATION =====
# Server port
SERVER_PORT=8080

# Profile: dev, prod
SPRING_PROFILES_ACTIVE=dev

# Logging level: DEBUG, INFO, WARN, ERROR
LOGGING_LEVEL=DEBUG

# ===== DATABASE CONNECTION POOL =====
# HikariCP settings
DATASOURCE_HIKARI_MAX_POOL_SIZE=10
DATASOURCE_HIKARI_MIN_IDLE=5
DATASOURCE_HIKARI_CONNECTION_TIMEOUT=20000

# ===== JPA/HIBERNATE =====
# DDL strategy: create, create-drop, update, validate
JPA_HIBERNATE_DDL_AUTO=validate
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=true

# ===== FILE UPLOAD =====
# Maximum file upload size (bytes)
# 5MB = 5242880
MAX_FILE_SIZE=5242880

# Upload directory
UPLOAD_DIR=./uploads

# ===== ACTUATOR =====
# Enable health checks, metrics, etc
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,metrics,info

# ===== CORS CONFIGURATION =====
# Allowed origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== SECURITY =====
# Account lockout settings
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

# ===== PAGINATION =====
# Default page size
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ===== NOTES =====
# 1. NEVER commit .env file to version control
# 2. Use different values for dev, staging, production
# 3. Regenerate JWT_SECRET regularly in production
# 4. Keep sensitive values secure
# 5. Use secrets management tools (AWS Secrets Manager, Vault, etc) in production
